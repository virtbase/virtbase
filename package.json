{
  "name": "virtbase",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "Janic Bellmann <contact@janic.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/virtbase/virtbase"
  },
  "bugs": {
    "url": "https://github.com/virtbase/virtbase/issues"
  },
  "homepage": "https://virtbase.com",
  "keywords": [
    "vps",
    "cloud",
    "hosting"
  ],
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=22.21.0"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:push": "turbo -F @virtbase/db push",
    "db:studio": "turbo -F @virtbase/db studio",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @virtbase/web...",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "email": "turbo run email",
    "prepare": "husky",
    "script": "turbo -F @virtbase/web script --",
    "stripe:listen": "turbo -F @virtbase/web stripe:listen"
  },
  "catalog": {
    "@biomejs/biome": "^2.4.10",
    "@tanstack/react-query": "^5.96.1",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "@types/bun": "1.3.11",
    "typescript": "^5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "catalog:",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.3"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "overrides": {
    "@better-auth/core": "1.5.6"
  }
}
