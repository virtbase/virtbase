{
  "name": "virtbase",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "Janic Bellmann <contact@janic.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/virtbase/virtbase"
  },
  "bugs": {
    "url": "https://github.com/virtbase/virtbase/issues"
  },
  "homepage": "https://virtbase.com",
  "keywords": [
    "vps",
    "cloud",
    "hosting"
  ],
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=22.21.0"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:generate": "turbo -F @virtbase/db db:generate",
    "db:migrate": "turbo -F @virtbase/db db:migrate",
    "db:push": "turbo -F @virtbase/db db:push",
    "db:studio": "turbo -F @virtbase/db db:studio",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @virtbase/web...",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "email": "turbo run email",
    "prepare": "husky",
    "script": "turbo -F @virtbase/web script --",
    "stripe:listen": "turbo -F @virtbase/web stripe:listen"
  },
  "catalog": {
    "@better-auth/api-key": "^1.6.9",
    "@better-auth/oauth-provider": "^1.6.9",
    "@better-auth/passkey": "^1.6.9",
    "@biomejs/biome": "^2.4.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "@types/bun": "1.3.13",
    "better-auth": "^1.6.9",
    "next": "^16.2.4",
    "nuqs": "^2.8.9",
    "postcss": "^8.5.12",
    "proxmox-api": "^1.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "use-intl": "^4.9.1",
    "workflow": "^4.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "overrides": {
    "@sentry/webpack-plugin": "5.1.1",
    "@sentry/bundler-plugin-core": "5.1.1"
  }
}
