{
  "name": "virtbase",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "Janic Bellmann <contact@janic.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/virtbase/virtbase"
  },
  "bugs": {
    "url": "https://github.com/virtbase/virtbase/issues"
  },
  "homepage": "https://virtbase.com",
  "keywords": [
    "vps",
    "cloud",
    "hosting"
  ],
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24.15.0"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:generate": "turbo -F @virtbase/db db:generate",
    "db:migrate": "turbo -F @virtbase/db db:migrate",
    "db:push": "turbo -F @virtbase/db db:push",
    "db:studio": "turbo -F @virtbase/db db:studio",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @virtbase/web...",
    "discord:register-commands": "turbo -F @virtbase/discord register-commands",
    "discord:register-connections-metadata": "turbo -F @virtbase/discord register-connections-metadata",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "email": "turbo run email",
    "prepare": "husky",
    "script": "turbo -F @virtbase/web script --",
    "stripe:listen": "turbo -F @virtbase/web stripe:listen"
  },
  "catalog": {
    "@better-auth/api-key": "^1.7.0-rc.0",
    "@better-auth/passkey": "^1.7.0-rc.0",
    "@biomejs/biome": "^2.5.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@trpc/tanstack-react-query": "^11.18.0",
    "@types/bun": "1.3.14",
    "better-auth": "^1.7.0-rc.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.1",
    "nuqs": "^2.9.0",
    "postcss": "^8.5.16",
    "proxmox-api": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "use-intl": "^4.13.1",
    "workflow": "^4.5.0",
    "zod": "^4.4.3"
  },
  "catalogs": {
    "sentry": {
      "@sentry/core": "10.62.0",
      "@sentry/nextjs": "10.62.0",
      "@sentry/node": "10.62.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.9.18"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "patchedDependencies": {
    "@ai-sdk/provider-utils@5.0.2": "patches/@ai-sdk-provider-utils@5.0.2.patch"
  },
  "overrides": {
    "@vue/compiler-core": "3.5.32",
    "@vue/compiler-dom": "3.5.32",
    "@vue/compiler-sfc": "3.5.32",
    "@vue/compiler-ssr": "3.5.32",
    "@vue/reactivity": "3.5.32",
    "@vue/runtime-core": "3.5.32",
    "@vue/runtime-dom": "3.5.32",
    "@vue/server-renderer": "3.5.32",
    "@vue/shared": "3.5.32",
    "vue": "3.5.32"
  }
}
