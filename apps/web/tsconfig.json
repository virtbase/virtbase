{
  "extends": "@virtbase/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "paths": {
      "fdx-source/*": ["./.source/*"],
      "@/*": ["./src/*"]
    },
    "plugins": [{ "name": "next" }, { "name": "workflow" }]
  },
  "include": [".", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
