{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "src/app/.well-known/workflow/**",
        ".source/**",
        "src/i18n/messages/**"
      ]
    },
    "dev": {
      "persistent": true
    }
  }
}
