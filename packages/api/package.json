    "@virtbase/email": "workspace:*",
    "@virtbase/utils": "workspace:*",
    "@virtbase/validators": "workspace:*",
    "proxmox-api": "catalog:",
    "server-only": "^0.0.1",
    "stripe": "^22.1.0",
    "superjson": "catalog:",
    "trpc-to-openapi": "^3.2.0",
    "use-intl": "catalog:",
    "workflow": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@simplewebauthn/server": "^13.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@virtbase/tsconfig": "workspace:*",
