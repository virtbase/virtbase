{
  "name": "@virtbase/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./proxmox": {
      "types": "./dist/proxmox.d.ts",
      "default": "./src/proxmox/index.ts"
    },
    "./stripe": {
      "types": "./dist/stripe.d.ts",
      "default": "./src/stripe/index.ts"
    },
    "./anonpay": {
      "types": "./dist/anonpay.d.ts",
      "default": "./src/anonpay/index.ts"
    },
    "./anonpay/constants": {
      "types": "./dist/anonpay/constants.d.ts",
      "default": "./src/anonpay/constants.ts"
    },
    "./lexware": {
      "types": "./dist/lexware.d.ts",
      "default": "./src/lexware/index.ts"
    },
    "./powerdns": {
      "types": "./dist/powerdns.d.ts",
      "default": "./src/powerdns/index.ts"
    },
    "./workflows": {
      "types": "./dist/workflows.d.ts",
      "default": "./src/workflows/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
