{
  "name": "@virtbase/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./test-client": {
      "types": "./dist/test-client.d.ts",
      "default": "./src/test-client.ts"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./src/schema/index.ts"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./src/utils/index.ts"
    },
    "./queries": {
      "types": "./dist/queries/index.d.ts",
      "default": "./src/queries/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "db:generate": "bun with-env drizzle-kit generate",
    "db:migrate": "bun with-env drizzle-kit migrate",
    "db:push": "bun with-env drizzle-kit push",
    "db:studio": "bun with-env drizzle-kit studio",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "bun --env-file ../../.env --"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "base-x": "^5.0.1",
    "drizzle-orm": "1.0.0-beta.22",
    "ws": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@electric-sql/pglite": "^0.4.5",
    "@types/ws": "^8.18.1",
    "@virtbase/tsconfig": "workspace:*",
    "drizzle-kit": "1.0.0-rc.2",
    "pg": "^8.20.0",
    "typescript": "catalog:"
  }
}
