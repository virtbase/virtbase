{
  "name": "@virtbase/email",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./resend": {
      "import": "./src/resend/index.ts",
      "require": "./src/resend/index.ts"
    },
    "./resend/*": {
      "import": "./src/resend/*.ts",
      "require": "./src/resend/*.ts"
    },
    "./templates/*": {
      "import": "./src/templates/*.tsx",
      "require": "./src/templates/*.tsx"
    },
    "./translations": {
      "import": "./src/translations/index.ts",
      "require": "./src/translations/index.ts"
    },
    "./send-via-nodemailer": {
      "import": "./src/send-via-nodemailer.ts",
      "require": "./src/send-via-nodemailer.ts"
    }
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "email": "email dev --dir ./src/templates -p 3333",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@virtbase/utils": "workspace:*",
    "nodemailer": "^8.0.7",
    "react-email": "^6.0.5",
    "resend": "^6.12.2",
    "use-intl": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@react-email/preview-server": "^5.2.10",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@virtbase/tsconfig": "workspace:*",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
